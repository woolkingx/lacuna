+// LACUNA PATCH: Helper function to convert favicon data to data URI
+function convertFaviconToDataURI(faviconURI, callback) {
+  try {
+    PlacesUtils.favicons.getFaviconDataForPage(
+      faviconURI,
+      (iconURI, dataLen, data, mimeType) => {
+        if (data && data.length > 0) {
+          // Convert binary data to base64
+          let base64 = btoa(String.fromCharCode.apply(null, data));
+          let dataURI = `data:${mimeType};base64,${base64}`;
+          callback(dataURI);
+        } else {
+          callback(null);
+        }
+      }
+    );
+  } catch (e) {
+    callback(null);
+  }
+}
+// END LACUNA PATCH
